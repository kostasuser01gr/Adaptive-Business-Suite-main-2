# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway Postgres plugin injects this automatically)
DATABASE_URL=postgresql://user:password@host:5432/database

# Long random string used to sign session cookies (generate with: openssl rand -hex 64)
SESSION_SECRET=replace-with-a-long-random-string

# ── Optional server config ────────────────────────────────────────────────────

# Runtime mode
NODE_ENV=development

# Host / port (Railway injects PORT automatically)
HOST=0.0.0.0
PORT=5000

# Database connection hardening
DATABASE_SSL_MODE=auto
DATABASE_POOL_MAX=10

# Comma-separated frontend origins allowed to send cookie-authenticated requests
# Local example:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Session / cookie settings
SESSION_COOKIE_NAME=abs.sid

# Local development should stay lax. For Railway + Vercel cross-site deployments use none.
SESSION_COOKIE_SAME_SITE=lax

# Set to "false" only for plain-HTTP test environments (e.g., Playwright E2E).
# Omit entirely in production — cookies are Secure when this is unset.
# SESSION_COOKIE_SECURE=false

# Optional shared cookie domain when serving app/api on the same apex.
# SESSION_COOKIE_DOMAIN=.example.com

# Session TTL in hours
SESSION_TTL_HOURS=720

# Optional logging control
LOG_LEVEL=info

# ── AI model provider ─────────────────────────────────────────────────────────

# "none" (default) — deterministic rule-based assistant, no external API calls
# "openai"         — routes assistant commands through OpenAI chat completions
AI_PROVIDER=none

# Required when AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# OpenAI model to use (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Override the OpenAI-compatible base URL (e.g., for local Ollama or LM Studio)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── Frontend (Vercel / local SPA) ─────────────────────────────────────────────

# Leave unset for same-origin local dev. Set this on Vercel to your Railway API URL.
# VITE_API_BASE_URL=https://your-railway-service.up.railway.app
